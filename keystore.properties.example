# Keystore properties configuration template
# Copy this file to keystore.properties in the root directory and fill in your signing credentials.

# Path to the keystore file (relative to root project directory or absolute)
storeFile=release.jks

# Keystore password
storePassword=your_keystore_password

# Key alias
keyAlias=your_key_alias

# Key password
keyPassword=your_key_password
